generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

// ── 管理员用户 ──
model User {
  id           String   @id @default(uuid())
  username     String   @unique
  passwordHash String
  nickname     String
  avatar       String?
  bio          String?
  socialLinks  String?                     // JSON 字符串
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

// ── 分类 ──
model Category {
  id    String @id @default(uuid())
  name  String @unique
  slug  String @unique
  posts Post[]
}

// ── 文章 ──
model Post {
  id          String     @id @default(uuid())
  title       String
  slug        String     @unique
  content     String
  excerpt     String?
  status      String     @default("DRAFT") // DRAFT | PUBLISHED
  categoryId  String?
  category    Category?  @relation(fields: [categoryId], references: [id])
  publishedAt DateTime?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  deletedAt   DateTime?
}
